{
  "agent": {
    "security_mode": "enforced",
    "policy_file": "AGENTS.md"
  },
  "sandbox": {
    "mode": "workspace-write",
    "network_access": false
  },
  "hooks": {
    "pre_commit": {
      "enabled": true,
      "timeout_seconds": 30,
      "block_on_critical": true,
      "auto_fix": ["formatting", "simple_secrets"]
    },
    "pre_push": {
      "enabled": true,
      "run_full_analysis": false
    }
  },
  "ci": {
    "mode": "full",
    "sarif_export": true,
    "pr_comments": true,
    "fail_on": ["critical", "high"]
  }
}